        "import random\n",
        "ver = random.randint(0, 100)\n",
        "print(ver)\n",
        "if ver % 3 == 0 and ver % 5 == 0:\n",
        "    print(\"FizzBuzz\")\n",
        "elif ver % 3 == 0:\n",
        "    print(\"Fizz\")\n",
        "elif ver % 5 == 0:\n",
        "    print(\"Buzz\")\n",
        "else:\n",
        "    print(ver)"
