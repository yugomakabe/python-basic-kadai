        "class Human:\n",
        "    def __init__(self, name, age ):\n",
        "        self.name = name\n",
        "        self.age = age\n",
        "    def printinfo(self):\n",
        "        print(self.name)\n",
        "        print(self.age)\n",
        "\n",
        "human = Human(\"侍太郎\", \"20\" )\n",
        "human.printinfo()"
